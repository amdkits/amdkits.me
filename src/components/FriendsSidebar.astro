---
// src/components/FriendsWindow.astro

const friendBadges = [
  { name: "melqtx", url: "https://melqtx.com", badge: "https://melqtx.com/images/mel-88x31.png?v=0e3ee4d"},
];

const embedCode = `<a href="https://amdkits.me" title="amdkits">
  <img src="https://amdkits.me/kits.gif" alt="amdkits" width="88" height="31" style="image-rendering: pixelated; border: none;">
</a>`;
---

<!-- Hidden checkbox to control window state -->
<input type="checkbox" id="window-minimize" class="window-toggle" />

<div class="os-window">
  <!-- Title Bar -->
  <div class="title-bar">
    <div class="title-text">
      <span class="blink">@</span>friends
    </div>
    
    <!-- The label acts as the minimize/maximize button -->
    <label for="window-minimize" class="control-btn">
      <span class="icon-min">[ - ]</span>
      <span class="icon-max">[ + ]</span>
    </label>
  </div>

  <!-- Window Body -->
  <div class="window-body">
    <div class="badge-grid">
      {friendBadges.map((friend) => (
        <a href={friend.url} target="_blank" title={friend.name}>
          <img src={friend.badge} alt={`${friend.name} badge`} class="pixel-art" width="88" height="31" />
        </a>
      ))}
    </div>

    <div class="divider"></div>

    <div class="my-badge-container">
      <img src="/kits.gif" alt="amdkits blinkie" class="pixel-art" width="88" height="31" />
    </div>
    <textarea class="code-box" readonly onclick="this.select()">{embedCode}</textarea>
  </div>
</div>

<style>
  /* Hidden Toggle */
  .window-toggle {
    display: none;
  }

  /* Main Window Container - Floating bottom right */
  .os-window {
    position: fixed;
    /* Adjusted so the title bar doesn't jump when minimized */
    bottom: 60px; 
    right: 20px;
    width: 260px;
    background: var(--bg);
    border: 1px solid var(--border);
    font-family: "Courier New", monospace;
    z-index: 50;
    box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.5);
  }

  /* Title Bar Styling */
  .title-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--konata-blue-soft); 
    color: var(--bg);
    padding: 3px 8px;
    font-weight: bold;
    font-size: 0.85rem;
  }

  /* Only blink the > cursor, not the whole word */
  .blink {
    animation: blinker 1s step-end infinite;
  }

  @keyframes blinker {
    50% { opacity: 0; }
  }

  /* Minimize Button Base */
  .control-btn {
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0 4px;
    user-select: none;
    transition: background 0.2s, color 0.2s;
  }

  .control-btn:hover {
    background: var(--bg);
    color: var(--konata-blue-soft);
  }

  /* Hide the Maximize button by default */
  .icon-max {
    display: none;
  }

  /* Window Body (Content) */
  .window-body {
    padding: 15px;
    background: var(--bg);
    /* Prevents window from growing too tall */
    max-height: 50vh; 
    /* Enables scrolling when you have many friends */
    overflow-y: auto; 
  }

  /* Custom Scrollbar for the retro vibe */
  .window-body::-webkit-scrollbar {
    width: 6px;
  }
  .window-body::-webkit-scrollbar-track {
    background: var(--bg);
    border-left: 1px solid var(--border);
  }
  .window-body::-webkit-scrollbar-thumb {
    background: var(--konata-blue-soft);
  }

  /* --- MINIMIZE LOGIC --- */
  
  /* 1. Hide the body when minimized */
  .window-toggle:checked ~ .os-window .window-body {
    display: none;
  }

  /* 2. Remove shadow when collapsed */
  .window-toggle:checked ~ .os-window {
    box-shadow: none;
    /* Maintain the exact same bottom position so it stays still */
    bottom: 60px; 
    border-bottom: 1px solid var(--border);
  }

  /* 3. Swap the icons: Hide [-] and Show [+] */
  .window-toggle:checked ~ .os-window .icon-min {
    display: none;
  }
  .window-toggle:checked ~ .os-window .icon-max {
    display: inline;
  }  
  
  /* Content Styling */
  .badge-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    justify-items: center;
  }

  .pixel-art {
    image-rendering: pixelated;
    border: 1px solid var(--border);
    transition: transform 0.1s ease;
  }

  .pixel-art:hover {
    transform: translateY(-2px);
  }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 15px 0;
  }

  .my-badge-container {
    text-align: center;
    margin-bottom: 8px;
  }

  .code-box {
    width: 100%;
    height: 70px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--konata-blue-soft);
    font-family: "Courier New", monospace;
    font-size: 0.65rem;
    padding: 4px;
    resize: none;
  }

  .code-box::selection {
    background: var(--konata-blue-soft);
    color: var(--bg);
  }
</style>
