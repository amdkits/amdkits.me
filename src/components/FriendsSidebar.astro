---
// src/components/FriendsWindow.astro

const friendBadges = [
  { name: "melqtx", url: "https://melqtx.com", badge: "https://melqtx.com/images/mel-88x31.png?v=0e3ee4d"},
];

const embedCode = `<a href="https://amdkits.me" title="amdkits">
  <img src="https://amdkits.me/kits.gif" alt="amdkits" width="88" height="31" style="image-rendering: pixelated; border: none;">
</a>`;
---

<!-- Hidden checkbox to control window state -->
<input type="checkbox" id="window-minimize" class="window-toggle" />

<div class="os-window">
  <!-- Title Bar -->
  <div class="title-bar">
    <div class="title-text">
      <span>friends</span>
    </div>
    <!-- The label acts as the minimize/maximize button -->
    <label for="window-minimize" class="control-btn">[ _ ]</label>
  </div>

  <!-- Window Body -->
  <div class="window-body">
    <div class="badge-grid">
      {friendBadges.map((friend) => (
        <a href={friend.url} target="_blank" title={friend.name}>
          <img src={friend.badge} alt={`${friend.name} badge`} class="pixel-art" width="88" height="31" />
        </a>
      ))}
    </div>

    <div class="divider"></div>

    <div class="my-badge-container">
      <img src="/kits.gif" alt="amdkits blinkie" class="pixel-art" width="88" height="31" />
    </div>
    <textarea class="code-box" readonly onclick="this.select()">{embedCode}</textarea>
  </div>
</div>

<style>
  /* Hidden Toggle */
  .window-toggle {
    display: none;
  }

  /* Main Window Container - Floating bottom right */
  .os-window {
    position: fixed;
    bottom: 60px;
    right: 20px;
    width: 260px;
    background: var(--bg);
    border: 1px solid var(--border);
    font-family: "Courier New", monospace;
    z-index: 50;
    /* Optional drop shadow for floating effect */
    box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.5);
  }

  /* Title Bar Styling */
  .title-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    /* Using your accent color for the title bar background */
    background: var(--konata-blue-soft); 
    color: var(--bg);
    padding: 3px 8px;
    font-weight: bold;
    font-size: 0.85rem;
  }

  .title-text span {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  /* Minimize Button */
  .control-btn {
    cursor: pointer;
    font-size: 0.8rem;
    padding: 0 4px;
    user-select: none;
    transition: background 0.2s;
  }

  .control-btn:hover {
    background: var(--bg);
    color: var(--konata-blue-soft);
  }

  /* Window Body (Content) */
  .window-body {
    padding: 15px;
    background: var(--bg);
  }

  /* --- MINIMIZE LOGIC --- */
  /* When the checkbox is checked, hide the body */
  .window-toggle:checked ~ .os-window .window-body {
    display: none;
  }

  /* When minimized, drop it flat against the bottom of the screen */
  .window-toggle:checked ~ .os-window {
    bottom: 65px;
    box-shadow: none;
    border-bottom: none;
  }

  /* Change button text to a square/restore icon when minimized */
  .window-toggle:checked ~ .os-window .control-btn::after {
    content: " [ + ]";
    position: absolute;
    right: 8px;
    background: inherit;
  }
  .window-toggle:checked ~ .os-window .control-btn {
    color: transparent; /* hide the underscore */
  }

  /* Content Styling */
  .badge-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    justify-items: center;
  }

  .pixel-art {
    image-rendering: pixelated;
    border: 1px solid var(--border);
    transition: transform 0.1s ease;
  }

  .pixel-art:hover {
    transform: translateY(-2px);
  }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 15px 0;
  }

  .my-badge-container {
    text-align: center;
    margin-bottom: 8px;
  }

  .code-box {
    width: 100%;
    height: 70px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--konata-blue-soft);
    font-family: "Courier New", monospace;
    font-size: 0.65rem;
    padding: 4px;
    resize: none;
  }

  .code-box::selection {
    background: var(--konata-blue-soft);
    color: var(--bg);
  }
</style>
