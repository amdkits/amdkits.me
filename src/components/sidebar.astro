---
import Webring from "./Webring.astro";
const links = [
  { href: "/", label: "home" },
  { href: "/blogs", label: "blog" },
  { href: "/about", label: "about" },
  { href: "/projects", label: "projects" },
  { href: "/now", label: "now" },
  { href: "/library", label: "library" },
  { href: "/garden", label: "garden" },
  { href: "/changelog", label: "changelog" },
  { href: "/uses", label: "uses" },
  { href: "/guestbook", label: "guestbook" },
  { href: "/colophon", label: "colophon" },
  { href: "/contact", label: "contact" },
  { href: "/gpg", label: "gpg" },
  { href: "/rss.xml", label: "rss" },
];

const current = Astro.url.pathname;
---

<input type="checkbox" id="sidebar-toggle" class="sidebar-toggle-input" />
<label for="sidebar-toggle" class="sidebar-handle">≡</label>

<aside class="sidebar">
  <nav>
    <ul>
      {
        links.map((l) => (
          <li>
            <a href={l.href} class={current === l.href ? "active" : ""}>
              {current === l.href ? "> " : ""}
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
    <Webring />
  </nav>
</aside>

<style>
  .sidebar-toggle-input {
    display: none;
  }

  .sidebar-handle {
    position: absolute;

    left: calc(100px + 500px + 0px);
    top: 354px;

    z-index: 10;
    cursor: pointer;
    color: var(--konata-blue-soft);
    font-family: "Courier New", monospace;
    font-size: 1.2rem;
    background: var(--titlebar-bg);
    padding: 0.2rem 0.55rem;
    border-radius: 1px;
  }

  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: 180px;
    background: var(--bg);
    border-right: 1px solid var(--border);
    padding: 3rem 0.8rem 1rem;
    font-family: "Courier New", monospace;
    font-size: 0.85rem;
    transform: translateX(-100%);
    transition: transform 0.2s ease;
    z-index: 9;
  }

  .sidebar-toggle-input:checked ~ .sidebar {
    transform: translateX(0);
  }

  .sidebar ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar li {
    padding: 0.3rem 0;
  }

  .sidebar a {
    color: var(--border);
    text-decoration: none;
  }

  .sidebar a:hover {
    color: var(--konata-blue-soft);
  }

  .sidebar a.active {
    color: var(--konata-blue-soft);
  }
</style>
