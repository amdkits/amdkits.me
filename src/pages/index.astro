---
<Base title="home">
  <div class="updates">
    <h2>updates</h2>
    <ul>
      {updates.map((u) => (
        <li>
          <span class="date">{u.date}</span>
          <span class="sep">·</span>
          <a href="#">
            <span class="tag">[{u.tag}]</span>
            <span class="label">{u.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>
