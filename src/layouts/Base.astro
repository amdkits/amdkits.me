---
import { ClientRouter } from "astro:transitions";
import '../styles/dark.css';
import Sidebar from '../components/sidebar.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
const { title = "amdkits" } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>amdkits — {title}</title>
  <ClientRouter />
</head>
<body>
<div id="oneko" transition:persist></div>
<script src="/oneko.js" is:inline></script>
      <MusicPlayer />
      <Sidebar />
  <div class="page">
    <div class="box">

    <div class="hero">
      <a href="/" class="moon-link">
      <div class="moon">
        <svg viewBox="0 0 100 100" width="80" height="80">
          <circle cx="50" cy="50" r="40" fill="var(--konata-blue-soft)" />
          <circle cx="65" cy="38" r="6" fill="var(--bg)" opacity="0.4" />
          <circle cx="40" cy="60" r="9" fill="var(--bg)" opacity="0.4" />
        </svg>
      </div>
      <h1 class="wordmark">a m d k i t s</h1>
      </a>
    </div>

    <div class="window">
      <div class="titlebar"><span>⛩️ El, Psy, Congroo</span></div>

      <div class="navbar">
      <nav class="navrow">
        <a href="/">home</a>
        <a href="blogs">blogs</a>
        <a href="https://x.com/amdkits">twt</a>
        <a href="https://leetcode.com/u/amdkits/">leetcode</a>
      </nav>
      </div>

      <slot />
    </div>
    </div>

  </div>
</body>
</html>
